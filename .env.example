# Database — Neon Postgres (or any PostgreSQL provider)
DATABASE_URL="postgresql://user:password@host:5432/flexora?sslmode=verify-full"

# Session secret (used for cookie signing — generate a random 64-char hex string)
# openssl rand -hex 32
SESSION_SECRET=""

# App URL (for redirects and public links)
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
