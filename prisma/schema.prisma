// This is your Prisma schema file - Prisma v7
// URL is configured in prisma.config.ts (not here)

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String
  avatarUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspaceMembers WorkspaceMember[]
  createdItems     Item[]            @relation("ItemCreator")
  comments         Comment[]
  assignedTasks    Task[]            @relation("TaskAssignee")
  createdTasks     Task[]            @relation("TaskCreator")
  notifications    Notification[]
  sessions         Session[]
  activityLogs     ActivityLog[]
  apiKeys          ApiKey[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  color       String   @default("#6366f1")
  iconEmoji   String   @default("🏢")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     WorkspaceMember[]
  apps        App[]
  apiKeys     ApiKey[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        String    @default("member")
  joinedAt    DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model App {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  iconEmoji   String   @default("📋")
  color       String   @default("#6366f1")
  fieldsJson  String   @default("[]")
  viewType    String   @default("table")
  shareToken     String?  @unique
  formToken      String?  @unique
  formFieldsJson String   @default("{}")
  createdAt      DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items       Item[]
  automations Automation[]
}

model Item {
  id          String   @id @default(cuid())
  appId       String
  title       String
  dataJson    String   @default("{}")
  creatorId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  app              App            @relation(fields: [appId], references: [id], onDelete: Cascade)
  creator          User           @relation("ItemCreator", fields: [creatorId], references: [id])
  comments         Comment[]
  tasks            Task[]
  activityLogs     ActivityLog[]
  relationsFrom    ItemRelation[] @relation("RelationFrom")
  relationsTo      ItemRelation[] @relation("RelationTo")
}

model ActivityLog {
  id        String   @id @default(cuid())
  itemId    String
  userId    String
  action    String
  metaJson  String   @default("{}")
  createdAt DateTime @default(now())

  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model Comment {
  id        String   @id @default(cuid())
  itemId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])
}

model Task {
  id          String    @id @default(cuid())
  itemId      String
  title       String
  description String?
  assigneeId  String?
  creatorId   String
  status      String    @default("todo")
  priority    String    @default("medium")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  item        Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator     User      @relation("TaskCreator", fields: [creatorId], references: [id])
}

model Automation {
  id          String   @id @default(cuid())
  appId       String
  name        String
  isActive    Boolean  @default(true)
  triggerJson String   @default("{}")
  actionsJson String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)
}

model ItemRelation {
  id         String   @id @default(cuid())
  fieldId    String
  fromItemId String
  toItemId   String
  createdAt  DateTime @default(now())

  fromItem   Item     @relation("RelationFrom", fields: [fromItemId], references: [id], onDelete: Cascade)
  toItem     Item     @relation("RelationTo",   fields: [toItemId],   references: [id], onDelete: Cascade)

  @@unique([fieldId, fromItemId, toItemId])
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  name        String
  keyHash     String    @unique
  prefix      String
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
